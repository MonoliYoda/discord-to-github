# Discord bot token — the bot must be in the target server with the Message Content
# Intent (privileged) enabled, and View Channel + Read Message History + Send Messages
# (incl. Send Messages in Threads) on the forum channel — the last is needed to post the
# created issue's link back into the thread. The always-on bot (npm run bot) also needs
# the applications.commands scope (invite the app with it) and only the Guilds gateway intent.
DISCORD_BOT_TOKEN=

# Guild (server) ID the triage command is registered to — guild-scoped commands appear
# instantly. Right-click the server → Copy Server ID (Developer Mode on).
DISCORD_GUILD_ID=

# Comma-separated Discord user IDs allowed to run the "Triage to GitHub" command. Anyone
# else gets an ephemeral rejection. Right-click a user → Copy User ID.
AUTHORIZED_USER_IDS=

# Application (client) ID — only needed for the one-time Developer Portal invite step,
# not by the bot code (discord.js derives it from the token).
DISCORD_APP_ID=

# Set to true to make the bot's Create button do a dry run (print the GitHub request
# instead of creating the issue). Leave unset/empty for real issue creation.
BOT_DRY_RUN=

# Anthropic API key for the Claude extraction call.
ANTHROPIC_API_KEY=

# Model override (optional). Defaults to claude-opus-4-8.
ANTHROPIC_MODEL=claude-opus-4-8

# GitHub fine-grained PAT — Issues: read + write on the target repo.
GITHUB_TOKEN=

# Target repo for created issues, in owner/repo form.
GITHUB_REPO=owner/repo

# Path to the domain context doc injected into the extraction prompt (optional).
# Defaults to context/CONTEXT.md — copy context/DOMAIN_CONTEXT.md to that path and
# fill it in with your own project's context (CONTEXT.md is gitignored).
CONTEXT_FILE=context/CONTEXT.md
